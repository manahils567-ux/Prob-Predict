   "source": [
    "### Step 5: Phase 1 - Collect Listing URLs from Search Pages\n\nIterates through Zameen.com search result pages collecting listing URLs and basic fields (price, location, bedrooms, bathrooms, size) until the target count is reached."
   ],
   "id": "e8722b187a67d696"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-05-23T07:23:09.665610Z",
     "start_time": "2026-05-23T07:23:09.647888Z"
    }
   },
   "source": [
    "def scrape_search_pages(city, city_id, target):\n    listings = []\n    page = 1\n\n    while len(listings) < target:\n        url = f\"{BASE_URL}/Homes/{city}-{city_id}-{page}.html\"\n        print(f\"Search page {page}: collecting... (have {len(listings)}/{target})\")\n\n        try:\n            resp = requests.get(url, headers=HEADERS, timeout=15)\n            resp.raise_for_status()\n        except Exception as e:\n            print(f\"  Failed: {e}\")\n            break\n\n        soup  = BeautifulSoup(resp.text, \"lxml\")\n        cards = soup.select(\"main > div > div > div > div > ul > li\")\n\n        if not cards:\n            print(\"  No listings found. Stopping.\")\n            break\n\n        added = 0\n        for card in cards:\n            if len(listings) >= target:\n                break\n\n            price_tag    = card.select_one(\"span[aria-label='Price']\")\n            location_tag = card.select_one(\"div[aria-label='Location']\")\n            beds_tag     = card.select_one(\"span[aria-label='Beds']\")\n            baths_tag    = card.select_one(\"span[aria-label='Baths']\")\n            size_tag     = card.select_one(\"div[title] > div > div > span:nth-child(1)\")\n            link_tag     = card.select_one(\"a[href*='/Property/']\") or card.find('a', href=True)\n\n            if not price_tag:\n                continue\n\n            if size_tag is None and location_tag:\n                size_tag = location_tag.parent.select_one(\n                    \"div:nth-child(2) > div > span:nth-child(3)\"\n                )\n\n            price_text = price_tag.text.strip()    if price_tag    else \"\"\n            location   = location_tag.text.strip() if location_tag else \"\"\n            beds_text  = beds_tag.text.strip()     if beds_tag     else \"\"\n            baths_text = baths_tag.text.strip()    if baths_tag    else \"\"\n            size_text  = size_tag.text.strip()     if size_tag     else \"\"\n            href       = link_tag['href']          if link_tag     else \"\"\n            detail_url = BASE_URL + href if href.startswith('/') else href\n\n            listings.append({\n                \"city\"       : city,\n                \"location\"   : location,\n                \"price_text\" : price_text,\n                \"price_pkr\"  : convert_price(price_text) if price_text else None,\n                \"bedrooms\"   : int(beds_text)  if beds_text.isdigit()  else None,\n                \"bathrooms\"  : int(baths_text) if baths_text.isdigit() else None,\n                \"size_text\"  : size_text,\n                \"size_sqft\"  : convert_size(size_text) if size_text else None,\n                \"detail_url\" : detail_url,\n            })\n            added += 1\n\n        print(f\"  Added {added} listings from this page\")\n        page += 1\n        time.sleep(DELAY_SEARCH)\n\n    print(f\"\\nPhase 1 complete. Total listings collected: {len(listings)}\")\n    return listings"
   ],
   "id": "80038041b48d79ec",
   "outputs": [],
   "execution_count": 4
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 6: Phase 2 - Scrape Detail Pages for Extended Features\n\nVisits each individual listing URL collected in Phase 1 and extracts extended features: property type, built year, parking spaces, servant quarters, store rooms, kitchens, and drawing rooms.\n\nA 3 second delay is applied between requests to avoid triggering rate limiting."
   ],
   "id": "c857da4b1f166ce3"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-05-23T07:23:10.523309Z",
     "start_time": "2026-05-23T07:23:10.506431Z"
    }
   },
   "source": [
    "def scrape_detail_page(url):\n",
    "    result = {\n",
    "        \"property_type\"    : None,\n",
    "        \"built_year\"       : None,\n",
    "        \"parking_spaces\"   : None,\n",
    "        \"servant_quarters\" : None,\n",
    "        \"store_rooms\"      : None,\n",
    "        \"kitchens\"         : None,\n",
    "        \"drawing_rooms\"    : None,\n",
    "    }\n",
    "\n",
    "    if not url:\n",
    "        return result\n",
    "\n",
    "    try:\n",
    "        resp = requests.get(url, headers=HEADERS, timeout=15)\n",
    "        resp.raise_for_status()\n",
    "    except Exception as e:\n",
    "        return result\n",
    "\n",
    "    soup = BeautifulSoup(resp.text, \"lxml\")\n",
    "    import re as _re\n",
    "\n",
    "    def to_int(val):\n",
    "        try:\n",
    "            return int(_re.sub(r'[^0-9]', '', str(val)))\n",
    "        except:\n",
    "            return None\n",
    "\n",
    "    # --- Property Type ---\n",
    "    # From screenshot: the Details table has a row with 'Type' label and value like 'House'\n",
    "    # Find all td/dd elements, when one says exactly 'Type' grab the next sibling\n",
    "    VALID_TYPES = {'house', 'flat', 'farm house', 'upper portion', 'lower portion',\n",
    "                   'room', 'penthouse', 'studio apartment'}\n",
    "    for el in soup.find_all(['td', 'dd', 'span', 'div', 'li']):\n",
    "        if el.get_text(strip=True).lower() == 'type':\n",
    "            nxt = el.find_next_sibling()\n",
    "            if nxt:\n",
    "                val = nxt.get_text(strip=True)\n",
    "                if val.lower() in VALID_TYPES:\n",
    "                    result['property_type'] = val\n",
    "                    break\n",
    "    # Fallback: scan all text nodes for known property types\n",
    "    if not result['property_type']:\n",
    "        for el in soup.find_all(['td', 'span', 'div']):\n",
    "            val = el.get_text(strip=True)\n",
    "            if val.lower() in VALID_TYPES:\n",
    "                result['property_type'] = val\n",
    "                break\n",
    "\n",
    "    # --- Amenities ---\n",
    "    # Zameen renders these as plain text spans:\n",
    "    #   'Built in year: 2025', 'Parking Spaces: 1', etc.\n",
    "    all_text_nodes = [el.get_text(' ', strip=True) for el in soup.find_all(['span', 'li', 'div', 'p'])]\n",
    "\n",
    "    def find_amenity(patterns):\n",
    "        for node in all_text_nodes:\n",
    "            for pat in patterns:\n",
    "                m = _re.search(pat, node, _re.IGNORECASE)\n",
    "                if m:\n",
    "                    return m.group(1).strip()\n",
    "        return None\n",
    "\n",
    "    result['built_year']       = to_int(find_amenity([\n",
    "        r'built(?:\\s+in)?\\s+year[:\\s]+([0-9]{4})',\n",
    "        r'year\\s+built[:\\s]+([0-9]{4})',\n",
    "    ]))\n",
    "    result['parking_spaces']   = to_int(find_amenity([\n",
    "        r'parking\\s+spaces?[:\\s]+([0-9]+)',\n",
    "        r'parking[:\\s]+([0-9]+)',\n",
    "    ]))\n",
    "    result['servant_quarters'] = to_int(find_amenity([\n",
    "        r'servant\\s+quarters?[:\\s]+([0-9]+)',\n",
    "    ]))\n",
    "    result['store_rooms']      = to_int(find_amenity([\n",
    "        r'store\\s+rooms?[:\\s]+([0-9]+)',\n",
    "    ]))\n",
    "    result['kitchens']         = to_int(find_amenity([\n",
    "        r'kitchens?[:\\s]+([0-9]+)',\n",
    "    ]))\n",
    "    result['drawing_rooms']    = to_int(find_amenity([\n",
    "        r'drawing\\s+rooms?[:\\s]+([0-9]+)',\n",
    "    ]))\n",
    "\n",
    "    return result\n",
    "\n",
    "\n",
    "def enrich_with_details(listings):\n",
    "    total = len(listings)\n",
    "    print(f\"Starting Phase 2: visiting {total} detail pages...\")\n",
    "    print(f\"Estimated time: {round((total * DELAY_DETAIL) / 60, 1)} minutes\")\n",
    "    print(\"\")\n",
    "\n",
    "    for i, listing in enumerate(listings, 1):\n",
    "        url = listing.get(\"detail_url\", \"\")\n",
    "        details = scrape_detail_page(url)\n",
    "        listing.update(details)\n",
    "\n",
    "        if i % 25 == 0 or i == total:\n",
    "            print(f\"  Progress: {i}/{total} detail pages scraped\")\n",
    "\n",
    "        time.sleep(DELAY_DETAIL)\n",
    "\n",
    "    print(f\"\\nPhase 2 complete.\")\n",
    "    return listings\n",
    "\n",
    "print(\"Detail scraper functions ready.\")\n"
   ],
   "id": "f517759e5ef100ac",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Detail scraper functions ready.\n"
     ]
    }
   ],
   "execution_count": 5
  },
